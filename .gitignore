# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Secrets
.env

# OS
.DS_Store

# Internal planning docs — not for GitHub
/REPRODUCTION_PLAN.md
/Repo_Build_Plan_v2__Cohesive_Application_Story.md

# Model weights — never commit
models/

# Frozen reference binaries (steering vectors are large; the JSONs stay tracked)
data/reference/steering_vectors/*.pt

# Everything the new pipeline produces, EXCEPT final results JSONs and
# hand-authored instrument drafts (candidate dilemma sets are authored, not
# pipeline output — they must be versioned while calibration iterates)
data/generated/*
!data/generated/.gitkeep
!data/generated/dilemmas_v3_candidates.json

# Results: keep the checkpoint JSONs (they are the replication record), ignore stray junk
results/**/.DS_Store
